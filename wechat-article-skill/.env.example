# WeChat 新闻分析 LLM 配置
# 设置 USE_LLM=true 启用 LLM 分析，否则使用规则分析

USE_LLM=true

# LLM 服务配置
# 支持: openai, deepseek, anthropic
LLM_PROVIDER=yovole

# API 密钥
LLM_API_KEY=

# 模型名称
# OpenAI: gpt-4o-mini, gpt-4o
# DeepSeek: deepseek-chat
# Anthropic: claude-3-5-haiku-20241022
LLM_MODEL=DeepSeek-V3.2

# API 基础地址
LLM_BASE_URL=http://ds-api.yovole.com/v1
